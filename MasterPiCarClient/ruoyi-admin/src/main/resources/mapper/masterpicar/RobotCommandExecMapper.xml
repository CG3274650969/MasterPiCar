<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.masterpicar.mapper.RobotCommandExecMapper">
    
    <resultMap type="RobotCommandExec" id="RobotCommandExecResult">
        <result property="execId"    column="exec_id"    />
        <result property="messageId"    column="message_id"    />
        <result property="deviceId"    column="device_id"    />
        <result property="commandJson"    column="command_json"    />
        <result property="execStatus"    column="exec_status"    />
        <result property="execFeedback"    column="exec_feedback"    />
        <result property="execTime"    column="exec_time"    />
    </resultMap>

    <resultMap id="RobotCommandExecRobotDeviceResult" type="RobotCommandExec" extends="RobotCommandExecResult">
        <collection property="robotDeviceList" ofType="RobotDevice" column="exec_id" select="selectRobotDeviceList" />
    </resultMap>

    <resultMap type="RobotDevice" id="RobotDeviceResult">
        <result property="deviceId"    column="device_id"    />
        <result property="deviceName"    column="device_name"    />
        <result property="deviceSn"    column="device_sn"    />
        <result property="ipAddress"    column="ip_address"    />
        <result property="onlineStatus"    column="online_status"    />
        <result property="lastOnlineTime"    column="last_online_time"    />
        <result property="remark"    column="remark"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectRobotCommandExecVo">
        select exec_id, message_id, device_id, command_json, exec_status, exec_feedback, exec_time from robot_command_exec
    </sql>

    <select id="selectRobotCommandExecList" parameterType="RobotCommandExec" resultMap="RobotCommandExecResult">
        <include refid="selectRobotCommandExecVo"/>
        <where>  
            <if test="messageId != null "> and message_id = #{messageId}</if>
            <if test="deviceId != null "> and device_id = #{deviceId}</if>
            <if test="commandJson != null  and commandJson != ''"> and command_json = #{commandJson}</if>
            <if test="execStatus != null  and execStatus != ''"> and exec_status = #{execStatus}</if>
            <if test="execFeedback != null  and execFeedback != ''"> and exec_feedback = #{execFeedback}</if>
            <if test="execTime != null "> and exec_time = #{execTime}</if>
        </where>
    </select>
    
    <select id="selectRobotCommandExecByExecId" parameterType="Long" resultMap="RobotCommandExecRobotDeviceResult">
        select exec_id, message_id, device_id, command_json, exec_status, exec_feedback, exec_time
        from robot_command_exec
        where exec_id = #{execId}
    </select>

    <select id="selectRobotDeviceList" resultMap="RobotDeviceResult">
        select device_id, device_name, device_sn, ip_address, online_status, last_online_time, remark, create_time, update_time
        from robot_device
        where device_name = #{device_name}
    </select>

    <insert id="insertRobotCommandExec" parameterType="RobotCommandExec" useGeneratedKeys="true" keyProperty="execId">
        insert into robot_command_exec
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="messageId != null">message_id,</if>
            <if test="deviceId != null">device_id,</if>
            <if test="commandJson != null and commandJson != ''">command_json,</if>
            <if test="execStatus != null">exec_status,</if>
            <if test="execFeedback != null">exec_feedback,</if>
            <if test="execTime != null">exec_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="messageId != null">#{messageId},</if>
            <if test="deviceId != null">#{deviceId},</if>
            <if test="commandJson != null and commandJson != ''">#{commandJson},</if>
            <if test="execStatus != null">#{execStatus},</if>
            <if test="execFeedback != null">#{execFeedback},</if>
            <if test="execTime != null">#{execTime},</if>
         </trim>
    </insert>

    <update id="updateRobotCommandExec" parameterType="RobotCommandExec">
        update robot_command_exec
        <trim prefix="SET" suffixOverrides=",">
            <if test="messageId != null">message_id = #{messageId},</if>
            <if test="deviceId != null">device_id = #{deviceId},</if>
            <if test="commandJson != null and commandJson != ''">command_json = #{commandJson},</if>
            <if test="execStatus != null">exec_status = #{execStatus},</if>
            <if test="execFeedback != null">exec_feedback = #{execFeedback},</if>
            <if test="execTime != null">exec_time = #{execTime},</if>
        </trim>
        where exec_id = #{execId}
    </update>

    <delete id="deleteRobotCommandExecByExecId" parameterType="Long">
        delete from robot_command_exec where exec_id = #{execId}
    </delete>

    <delete id="deleteRobotCommandExecByExecIds" parameterType="String">
        delete from robot_command_exec where exec_id in 
        <foreach item="execId" collection="array" open="(" separator="," close=")">
            #{execId}
        </foreach>
    </delete>
    
    <delete id="deleteRobotDeviceByDeviceNames" parameterType="String">
        delete from robot_device where device_name in 
        <foreach item="deviceName" collection="array" open="(" separator="," close=")">
            #{deviceName}
        </foreach>
    </delete>

    <delete id="deleteRobotDeviceByDeviceName" parameterType="Long">
        delete from robot_device where device_name = #{deviceName}
    </delete>

    <insert id="batchRobotDevice">
        insert into robot_device( device_id, device_name, device_sn, ip_address, online_status, last_online_time, remark, create_time, update_time) values
        <foreach item="item" index="index" collection="list" separator=",">
            ( #{item.deviceId}, #{item.deviceName}, #{item.deviceSn}, #{item.ipAddress}, #{item.onlineStatus}, #{item.lastOnlineTime}, #{item.remark}, #{item.createTime}, #{item.updateTime})
        </foreach>
    </insert>
</mapper>